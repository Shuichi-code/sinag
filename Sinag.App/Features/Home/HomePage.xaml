<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sinag.App.Features.Home"
             xmlns:l="clr-namespace:Sinag.App.Helpers"
             x:Class="Sinag.App.Features.Home.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Surface}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══ Hero Section with Warm Gradient ═══ -->
            <Grid>
                <!-- Gradient background layer -->
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                            <GradientStop Color="#f8a010" Offset="0.0"/>
                            <GradientStop Color="#fcd47c" Offset="0.35"/>
                            <GradientStop Color="#fffbff" Offset="0.85"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Hero content -->
                <VerticalStackLayout Padding="24,20,24,32" Spacing="16">

                    <!-- Top bar: Logo + Language Picker -->
                    <Grid ColumnDefinitions="Auto,*">
                        <!-- Logo -->
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="☀" FontSize="22" VerticalOptions="Center"/>
                            <Label Text="Sinag"
                                   FontFamily="PlusJakartaSans"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Language Picker -->
                        <HorizontalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End"
                                               VerticalOptions="Center">
                            <Button Text="FIL"
                                    Command="{Binding SetLanguageCommand}"
                                    CommandParameter="fil"
                                    FontFamily="BeVietnamProBold"
                                    FontSize="10"
                                    CornerRadius="9999"
                                    HeightRequest="28"
                                    Padding="10,0"
                                    MinimumWidthRequest="0"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource OnSurfaceVariant}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding SelectedLanguage}" Value="fil">
                                        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLowest}"/>
                                        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button Text="EN"
                                    Command="{Binding SetLanguageCommand}"
                                    CommandParameter="en"
                                    FontFamily="BeVietnamProBold"
                                    FontSize="10"
                                    CornerRadius="9999"
                                    HeightRequest="28"
                                    Padding="10,0"
                                    MinimumWidthRequest="0"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource OnSurfaceVariant}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding SelectedLanguage}" Value="en">
                                        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLowest}"/>
                                        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button Text="BIS"
                                    Command="{Binding SetLanguageCommand}"
                                    CommandParameter="ceb"
                                    FontFamily="BeVietnamProBold"
                                    FontSize="10"
                                    CornerRadius="9999"
                                    HeightRequest="28"
                                    Padding="10,0"
                                    MinimumWidthRequest="0"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource OnSurfaceVariant}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding SelectedLanguage}" Value="ceb">
                                        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLowest}"/>
                                        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Overline badge -->
                    <Border BackgroundColor="#FFFBFF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,6"
                            HorizontalOptions="Start"
                            Opacity="0.85">
                        <Label Text="{l:Translate Home_Badge}"
                               Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource Primary}"/>
                    </Border>

                    <!-- Headline — LEFT aligned like reference -->
                    <Label Text="{l:Translate Home_Headline}"
                           FontFamily="PlusJakartaSans"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurface}"
                           HorizontalTextAlignment="Start"
                           LineHeight="1.05"
                           Margin="0,8,60,0"/>

                    <!-- Subtitle — LEFT aligned -->
                    <Label Text="{l:Translate Home_Subtitle}"
                           FontFamily="BeVietnamProRegular"
                           FontSize="15"
                           TextColor="{StaticResource OnSurfaceVariant}"
                           HorizontalTextAlignment="Start"
                           LineHeight="1.6"
                           Margin="0,0,0,8"/>

                    <!-- Primary CTA — Gradient Sun Button -->
                    <Button Text="{l:Translate Home_ScanButton}"
                            Command="{Binding ScanBillCommand}"
                            TextColor="White"
                            FontFamily="PlusJakartaSans"
                            FontSize="17"
                            FontAttributes="Bold"
                            CornerRadius="9999"
                            HeightRequest="58"
                            HorizontalOptions="Start"
                            Padding="32,0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#8d5900" Offset="0"/>
                                <GradientStop Color="#c07b00" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Shadow>
                            <Shadow Brush="#8d5900"
                                    Offset="0,10"
                                    Radius="28"
                                    Opacity="0.25"/>
                        </Button.Shadow>
                    </Button>

                    <!-- Manual entry link -->
                    <Label Text="{l:Translate Home_ManualLink}"
                           FontFamily="BeVietnamProMedium"
                           FontSize="14"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Start"
                           Padding="0,4">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ManualEntryCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Grid>

            <!-- ═══ How It Works ═══ -->
            <VerticalStackLayout Padding="24,32,24,8" Spacing="20"
                                 BackgroundColor="{StaticResource Surface}">

                <Label Text="{l:Translate Home_HowItWorks}"
                       FontFamily="PlusJakartaSans"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource OnSurface}"/>

                <!-- Step 1: LARGE lead card (matches reference) -->
                <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24"
                        Padding="24"
                        HeightRequest="200">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource PrimaryBrush}"
                                Offset="0,8" Radius="24" Opacity="0.06"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                            <Label Text="{l:Translate Home_Step1Title}"
                                   FontFamily="PlusJakartaSans"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurface}"/>
                            <Label Text="{l:Translate Home_Step1Desc}"
                                   FontFamily="BeVietnamProRegular"
                                   FontSize="14"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   LineHeight="1.6"/>
                        </VerticalStackLayout>
                        <!-- Rounded illustration circle -->
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource SurfaceContainerHighest}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 9999"
                                WidthRequest="80" HeightRequest="80"
                                VerticalOptions="Center">
                            <Label Text="📸"
                                   FontSize="36"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Steps 2 & 3 side-by-side (matches reference layout) -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <!-- Step 2 -->
                    <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="16"
                            HeightRequest="180">
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="{StaticResource SurfaceContainerHighest}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 9999"
                                    WidthRequest="52" HeightRequest="52"
                                    HorizontalOptions="Start">
                                <Label Text="✅"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="{l:Translate Home_Step2Title}"
                                   FontFamily="PlusJakartaSans"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurface}"/>
                            <Label Text="{l:Translate Home_Step2Desc}"
                                   FontFamily="BeVietnamProRegular"
                                   FontSize="12"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   LineHeight="1.5"
                                   MaxLines="4"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Step 3 -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource TertiaryContainer}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="16"
                            HeightRequest="180">
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 9999"
                                    WidthRequest="52" HeightRequest="52"
                                    HorizontalOptions="Start">
                                <Label Text="☀"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="{l:Translate Home_Step3Title}"
                                   FontFamily="PlusJakartaSans"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource OnTertiaryContainer}"/>
                            <Label Text="{l:Translate Home_Step3Desc}"
                                   FontFamily="BeVietnamProRegular"
                                   FontSize="12"
                                   TextColor="{StaticResource OnTertiaryContainer}"
                                   LineHeight="1.5"
                                   MaxLines="4"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <!-- ═══ Savings Tease Banner with Gradient ═══ -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Padding="24"
                    Margin="24,24,24,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#69f6b8" Offset="0"/>
                        <GradientStop Color="#00734e" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#00734e"
                            Offset="0,8" Radius="24" Opacity="0.15"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="{l:Translate Home_BannerTitle}"
                           FontFamily="PlusJakartaSans"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="{l:Translate Home_BannerDesc}"
                           FontFamily="BeVietnamProRegular"
                           FontSize="14"
                           TextColor="White"
                           Opacity="0.9"
                           LineHeight="1.6"/>
                </VerticalStackLayout>
            </Border>

            <!-- ═══ Footer ═══ -->
            <VerticalStackLayout BackgroundColor="{StaticResource SurfaceContainerHigh}"
                                 Padding="24,24,24,32"
                                 Spacing="8"
                                 Margin="0,32,0,0">
                <Label Text="Sinag"
                       FontFamily="PlusJakartaSans"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"/>
                <Label Text="{l:Translate Copyright}"
                       FontFamily="BeVietnamProRegular"
                       FontSize="11"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       HorizontalOptions="Center"
                       Opacity="0.7"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
