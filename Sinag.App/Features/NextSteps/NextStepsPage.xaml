<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sinag.App.Features.NextSteps"
             xmlns:models="clr-namespace:Sinag.App.Models"
             xmlns:l="clr-namespace:Sinag.App.Helpers"
             x:Class="Sinag.App.Features.NextSteps.NextStepsPage"
             x:DataType="vm:NextStepsViewModel"
             Title="{l:Translate Next_Title}"
             BackgroundColor="{StaticResource Surface}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══ Warm gradient accent bar ═══ -->
            <Grid HeightRequest="8">
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#f8a010" Offset="0"/>
                            <GradientStop Color="#69f6b8" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
            </Grid>

            <!-- ═══ Linear Steps — Reference Layout ═══ -->
            <VerticalStackLayout Padding="24,24,24,8" Spacing="24">

                <!-- Step 01 — Large number, prominent -->
                <Grid ColumnDefinitions="60,*" ColumnSpacing="12">
                    <Label Text="01"
                           FontFamily="PlusJakartaSans"
                           FontSize="42"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryContainer}"
                           VerticalOptions="Start"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Label Text="{l:Translate Next_Step1Title}"
                               FontFamily="PlusJakartaSans"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}"/>
                        <Label Text="{l:Translate Next_Step1Desc}"
                               FontFamily="BeVietnamProRegular"
                               FontSize="14"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               LineHeight="1.6"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Step 02 -->
                <Grid ColumnDefinitions="60,*" ColumnSpacing="12">
                    <Label Text="02"
                           FontFamily="PlusJakartaSans"
                           FontSize="42"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryContainer}"
                           VerticalOptions="Start"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Label Text="{l:Translate Next_Step2Title}"
                               FontFamily="PlusJakartaSans"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}"/>
                        <Label Text="{l:Translate Next_Step2Desc}"
                               FontFamily="BeVietnamProRegular"
                               FontSize="14"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               LineHeight="1.6"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Step 03 -->
                <Grid ColumnDefinitions="60,*" ColumnSpacing="12">
                    <Label Text="03"
                           FontFamily="PlusJakartaSans"
                           FontSize="42"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TertiaryContainer}"
                           VerticalOptions="Start"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Label Text="{l:Translate Next_Step3Title}"
                               FontFamily="PlusJakartaSans"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}"/>
                        <Label Text="{l:Translate Next_Step3Desc}"
                               FontFamily="BeVietnamProRegular"
                               FontSize="14"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               LineHeight="1.6"/>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>

            <!-- ═══ Installer Directory ═══ -->
            <VerticalStackLayout Padding="24,24,24,8" Spacing="8">
                <Label Text="{l:Translate Next_InstallerDir}"
                       FontFamily="PlusJakartaSans"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource OnSurface}"/>
                <Label Text="{l:Translate Next_InstallerSubtitle}"
                       FontFamily="BeVietnamProRegular"
                       FontSize="13"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       Margin="0,0,0,8"/>
            </VerticalStackLayout>

            <CollectionView ItemsSource="{Binding Installers}"
                            Margin="20,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:InstallerInfo">
                        <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                Margin="0,4">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource PrimaryBrush}"
                                        Offset="0,6" Radius="20" Opacity="0.05"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <!-- Icon circle -->
                                    <Border BackgroundColor="{StaticResource SurfaceContainerHighest}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 9999"
                                            WidthRequest="44" HeightRequest="44">
                                        <Label Text="☀"
                                               FontSize="20"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Name -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontFamily="PlusJakartaSans"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource OnSurface}"/>
                                        <Label Text="{Binding Description}"
                                               FontFamily="BeVietnamProRegular"
                                               FontSize="11"
                                               TextColor="{StaticResource OnSurfaceVariant}"/>
                                    </VerticalStackLayout>

                                    <!-- DOE Badge -->
                                    <Border Grid.Column="2"
                                            BackgroundColor="{StaticResource Tertiary}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 9999"
                                            Padding="8,4"
                                            IsVisible="{Binding IsDoeAccredited}"
                                            VerticalOptions="Center">
                                        <Label Text="DOE ✓"
                                               FontFamily="BeVietnamProBold"
                                               FontSize="9"
                                               TextColor="{StaticResource OnTertiary}"/>
                                    </Border>
                                </Grid>

                                <!-- Contact actions -->
                                <HorizontalStackLayout Spacing="16" Padding="56,0,0,0">
                                    <Label Text="{l:Translate Next_Call}"
                                           FontFamily="BeVietnamProMedium"
                                           FontSize="13"
                                           TextColor="{StaticResource Primary}"
                                           IsVisible="{Binding Phone, Converter={x:Null}}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NextStepsViewModel}}, Path=CallInstallerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label Text="{l:Translate Next_Website}"
                                           FontFamily="BeVietnamProMedium"
                                           FontSize="13"
                                           TextColor="{StaticResource Primary}"
                                           IsVisible="{Binding Website, Converter={x:Null}}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NextStepsViewModel}}, Path=OpenWebsiteCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Disclaimer -->
            <Label Text="{l:Translate Next_Disclaimer}"
                   FontFamily="BeVietnamProRegular"
                   FontSize="11"
                   TextColor="{StaticResource OnSurfaceVariant}"
                   FontAttributes="Italic"
                   HorizontalTextAlignment="Center"
                   Margin="20,16,20,0"/>

            <!-- Back to Home Button — Gradient -->
            <Button Text="{l:Translate Next_GoHome}"
                    Command="{Binding GoHomeCommand}"
                    TextColor="White"
                    FontFamily="PlusJakartaSans"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="9999"
                    HeightRequest="52"
                    Margin="20,16,20,8">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#8d5900" Offset="0"/>
                        <GradientStop Color="#c07b00" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Shadow>
                    <Shadow Brush="#8d5900"
                            Offset="0,8" Radius="24" Opacity="0.2"/>
                </Button.Shadow>
            </Button>

            <!-- Footer -->
            <VerticalStackLayout BackgroundColor="{StaticResource SurfaceContainerHigh}"
                                 Padding="24,20,24,32"
                                 Spacing="8"
                                 Margin="0,16,0,0">
                <Label Text="Sinag"
                       FontFamily="PlusJakartaSans"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"/>
                <Label Text="{l:Translate Copyright}"
                       FontFamily="BeVietnamProRegular"
                       FontSize="11"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       HorizontalOptions="Center"
                       Opacity="0.7"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
